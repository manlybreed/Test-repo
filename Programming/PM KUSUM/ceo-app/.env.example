DATABASE_URL="postgresql://bluridge:bluridge@localhost:5433/ceo_app?schema=public"
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"
ANTHROPIC_API_KEY="sk-ant-..."
CEO_EMAIL="ceo@thebluridge.com"
CEO_PASSWORD="change-me"
STORAGE_ROOT="./storage"

# Invoice email (docker-mailserver: mail.thebluridge.com)
SMTP_HOST="mail.thebluridge.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="invoices@thebluridge.com"
SMTP_PASS="replace-me"
MAIL_FROM="BluRidge Consulting <invoices@thebluridge.com>"
MAIL_ACCOUNTS_CC="accounts@thebluridge.com"
IMAP_HOST="mail.thebluridge.com"
IMAP_PORT="993"
IMAP_SECURE="true"
# Set to 1 to run live SMTP verify in vitest
# MAIL_LIVE_TEST="1"

# CEO mailbox for /ceo/mail (akshay@) — separate from invoices@
CEO_MAIL_HOST="mail.thebluridge.com"
CEO_MAIL_SMTP_PORT="587"
CEO_MAIL_IMAP_PORT="993"
CEO_MAIL_SMTP_SECURE="false"
CEO_MAIL_IMAP_SECURE="true"
CEO_MAIL_USER="akshay@thebluridge.com"
CEO_MAIL_PASS="replace-me"
CEO_MAIL_FROM="Akshay <akshay@thebluridge.com>"
# IMAP IDLE live sync (default on when CEO_MAIL_* set). Set 0 to disable.
# CEO_MAIL_IDLE="0"
# CEO_MAIL_LIVE_TEST="1"
