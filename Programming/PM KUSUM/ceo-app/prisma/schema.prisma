generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Prisma 6 — URL in schema; docker compose on port 5433

enum Role {
  CEO
}

enum AgreementStatus {
  DRAFT
  FINAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TimeSessionKind {
  POMODORO
  BREAK
  MANUAL
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  role         Role          @default(CEO)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  chatThreads  ChatThread[]
  tasks        Task[]
  timeSessions TimeSession[]
}

model CompanyProfile {
  id           String   @id @default(cuid())
  legalName    String
  tradeName    String?
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  stateCode    String
  pincode      String?
  gstin        String
  pan          String?
  email        String?
  phone        String?
  bankName     String?
  bankAccount  String?
  bankIfsc     String?
  hsnDefault   String   @default("998313")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Client {
  id           String      @id @default(cuid())
  name         String
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  stateCode    String?
  pincode      String?
  gstin        String?
  pan          String?
  email        String?
  phone        String?
  /// Point of contact name
  pocName      String?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  agreements   Agreement[]
  invoices     Invoice[]
}

model Agreement {
  id              String              @id @default(cuid())
  clientId        String?
  client          Client?             @relation(fields: [clientId], references: [id])
  clientName      String
  clientAddress   String?
  clientGstin     String?
  clientPan       String?
  spvName         String?
  plantCount      Int                 @default(1)
  tokenFeePerPlant Float              @default(40000)
  successFeePct   Float               @default(1)
  gstPct          Float               @default(18)
  designatedLender String?
  interestRange   String?
  minLoan         String?
  maxLoan         String?
  tenure          String?
  moratorium      String?
  effectiveDate   DateTime            @default(now())
  termMonths      Int                 @default(9)
  tailMonths      Int                 @default(24)
  status          AgreementStatus     @default(DRAFT)
  isImported      Boolean             @default(false)
  notes           String?
  inputsJson      Json?
  filePath        String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  versions        AgreementVersion[]
}

model AgreementVersion {
  id          String    @id @default(cuid())
  agreementId String
  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  version     Int
  filePath    String
  inputsJson  Json?
  createdAt   DateTime  @default(now())
}

model Invoice {
  id             String        @id @default(cuid())
  number         String        @unique
  clientId       String?
  client         Client?       @relation(fields: [clientId], references: [id])
  buyerName      String
  buyerAddress   String?
  buyerGstin     String?
  buyerState     String?
  buyerStateCode String?
  invoiceDate    DateTime      @default(now())
  dueDate        DateTime?
  remarks        String?
  serviceDesc    String?
  taxableTotal   Float
  cgstAmount     Float
  sgstAmount     Float
  igstAmount     Float         @default(0)
  grandTotal     Float
  amountInWords  String?
  paymentStatus  String?       // PAID | UNPAID | PARTIAL | OVERDUE
  tdsDeducted    Boolean       @default(false)
  tdsPercent     Float?        // 5 | 10 | 20
  tdsAmount      Float?        // legacy — unused in UI
  gstEntity      String?       // DEL | RAJ — BluRidge GST under which invoice was raised
  isImported     Boolean       @default(false)
  sourceFilePath String?
  rawExtract     String?
  filePath       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  lines          InvoiceLine[]
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  hsn         String  @default("998313")
  quantity    Float   @default(1)
  rate        Float
  amount      Float
  sortOrder   Int     @default(0)
}

model Employee {
  id              String       @id @default(cuid())
  name            String
  employeeCode    String?      @unique
  designation     String?
  department      String?
  email           String?      // personal email
  emailOfficial   String?      // company / official email (manual)
  phone           String?
  pan             String?
  aadhaar         String?
  uan             String?
  addressLine1    String?
  city            String?
  state           String?
  pincode         String?
  bankAccount     String?
  bankIfsc        String?
  bankName        String?
  bankBranch      String?
  basic           Float
  hra             Float        @default(0)
  special         Float        @default(0)
  otherAllow      Float        @default(0)
  pf              Float        @default(0)
  professionalTax Float        @default(0)
  tdsPercent      Float        @default(0)  // TDS rate % applied on gross
  otherDeduct     Float        @default(0)
  joinDate        DateTime?
  dateOfBirth     DateTime?
  photoPath       String?
  panDocPath      String?
  aadhaarDocPath  String?
  agreementPath   String?
  bankDocPath     String?
  salarySlipPath  String?      // source salary slip used for breakup
  notes           String?
  rawExtract      String?
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  slips           SalarySlip[]
}

model SalarySlip {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month        Int
  year         Int
  basic        Float
  hra          Float
  special      Float
  otherAllow   Float
  gross        Float
  pf           Float
  professionalTax Float
  tds          Float
  otherDeduct  Float
  totalDeduct  Float
  netPay       Float
  amountInWords String?
  filePath     String?
  paymentStatus String  @default("UNPAID") // PAID | UNPAID
  createdAt    DateTime @default(now())

  @@unique([employeeId, month, year])
}

model Task {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  projectTag   String?
  clientTag    String?
  status       TaskStatus    @default(TODO)
  estimateMin  Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     TimeSession[]
}

model TimeSession {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId      String?
  task        Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  kind        TimeSessionKind @default(MANUAL)
  startedAt   DateTime
  endedAt     DateTime?
  durationSec Int?
  notes       String?
  createdAt   DateTime        @default(now())
}

model ChatThread {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String        @default("CEO Assistant")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id        String     @id @default(cuid())
  threadId  String
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role      String
  content   String
  toolCalls Json?
  createdAt DateTime   @default(now())
}

model InvoiceSequence {
  id      String @id @default("default")
  lastNum Int    @default(8)
}

model Expense {
  id               String   @id @default(cuid())
  date             DateTime
  vendor           String
  amount           Decimal  @db.Decimal(12, 2)
  category         String
  subCategory      String?
  description      String?
  paymentMode      String?
  gstAmount        Decimal? @db.Decimal(12, 2)
  gstEntity        String?  // DEL | RAJ — BluRidge GST under which vendor invoice was booked
  invoiceNo        String?
  invoiceNoNorm    String?  // normalized invoice number for de-duplication
  billedTo         String?  // raw "Billed to" text from the invoice
  billedToPartyId  String?
  billedToParty    BilledToParty? @relation(fields: [billedToPartyId], references: [id], onDelete: SetNull)
  ourGstMentioned  Boolean? // whether a BluRidge GSTIN appears on the bill
  billedGstin      String?  // BluRidge GSTIN found on the bill (if any)
  contentHash      String?  // sha256 of stored file — catches identical re-uploads
  filePath         String?
  rawExtract       String?
  notes            String?
  needsReview      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([invoiceNoNorm])
  @@index([contentHash])
  @@index([billedToPartyId])
}

/// Canonical bill-to party (deduped across expense receipts)
model BilledToParty {
  id            String          @id @default(cuid())
  canonicalName String
  normalized    String          @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  aliases       BilledToAlias[]
  expenses      Expense[]
}

model BilledToAlias {
  id        String       @id @default(cuid())
  partyId   String
  party     BilledToParty @relation(fields: [partyId], references: [id], onDelete: Cascade)
  rawName   String
  normalized String
  createdAt DateTime     @default(now())

  @@unique([partyId, normalized])
  @@index([normalized])
}

/// PM KUSUM plant / project finance file — folder-backed KYC pack + disclosure form
model KusumPlant {
  id                 String   @id @default(cuid())
  name               String
  /// Filename prefix e.g. "Solarseed Agri"
  plantShort         String?
  folderPath         String   @unique
  status             String   @default("DRAFT") // DRAFT | EXTRACTED | FORM_READY
  documentsFound     Int      @default(0)
  extractSummary     String?
  rawExtract         String?  // JSON from AI
  disclosureFilePath String?
  notes              String?
  /// Portfolio fields shown on the plants table
  capacityMw         String?
  tehsil             String?
  district           String?
  dprName            String?
  epcName            String?
  tariff             String?
  bankName           String?
  /// Success fee % (finance owner only)
  feePercent         Float?
  /// Sanctioned loan amount INR (finance owner only)
  sanctionAmount     Float?
  /// Quoted / expected interest rate %
  interestRate       Float?
  /// DOCUMENTATION | MAIL | FIELD_VISIT | CMA | SANCTION | DISBURSEMENT
  financeStage       String   @default("DOCUMENTATION")
  docsCompleteAt     DateTime?
  mailSentAt         DateTime?
  fieldVisitAt       DateTime?
  cmaAt              DateTime?
  sanctionAt         DateTime?
  disbursementAt     DateTime?
  sanctionLetterPath String?
  /// ACTIVE | INACTIVE
  activeStatus       String   @default("ACTIVE")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  parties      PlantParty[]
  requirements PlantDocRequirement[]
  fileComments PlantFileComment[]
  tasks        PlantTask[]
}

/// Director / promoter under a plant (maps to Directors KYC/<folderName>/)
model PlantParty {
  id         String   @id @default(cuid())
  plantId    String
  plant      KusumPlant @relation(fields: [plantId], references: [id], onDelete: Cascade)
  name       String
  role       String   @default("DIRECTOR") // DIRECTOR | PROMOTER
  folderName String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  requirements PlantDocRequirement[]

  @@index([plantId])
  @@unique([plantId, folderName])
}

/// Global checklist template (SPV / Directors / Plant / Land / …)
model DocTypeCatalog {
  id          String   @id @default(cuid())
  code        String   @unique
  docGroup    String   // SPV | DIRECTORS | PLANT | LAND | EPC | DPR | MISC | THIRD_PARTY
  label       String
  description String?
  scope       String   @default("PLANT") // PLANT | PARTY
  required    Boolean  @default(true)
  folderHint  String
  /// JSON string array of filename keywords
  matchHints  String   @default("[]")
  namePattern String   @default("{plantShort}-{label}")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requirements PlantDocRequirement[]
}

/// Per-plant (and optional per-party) checklist row
model PlantDocRequirement {
  id               String    @id @default(cuid())
  plantId          String
  plant            KusumPlant @relation(fields: [plantId], references: [id], onDelete: Cascade)
  catalogId        String
  catalog          DocTypeCatalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  partyId          String?
  party            PlantParty? @relation(fields: [partyId], references: [id], onDelete: Cascade)
  received         Boolean   @default(false)
  receivedAt       DateTime?
  fileRelativePath String?
  source           String?   // IMPORT | UPLOAD | MANUAL
  notes            String?
  /// REQUIRED | OPTIONAL | NA — NA means not needed for this plant
  applicability    String    @default("REQUIRED")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([plantId, catalogId, partyId])
  @@index([plantId])
  @@index([catalogId])
}

/// Per-file comment on a plant folder file (keyed by relative path)
model PlantFileComment {
  id           String     @id @default(cuid())
  plantId      String
  plant        KusumPlant @relation(fields: [plantId], references: [id], onDelete: Cascade)
  relativePath String
  comment      String     @default("")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([plantId, relativePath])
  @@index([plantId])
}

/// Tasks tied to a PM KUSUM plant / project
model PlantTask {
  id           String     @id @default(cuid())
  plantId      String
  plant        KusumPlant @relation(fields: [plantId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  status       TaskStatus @default(TODO)
  /// LOW | MEDIUM | HIGH | CRITICAL
  urgency      String     @default("MEDIUM")
  reminderAt   DateTime?
  /// GENTLE | NORMAL | URGENT
  reminderTone String     @default("NORMAL")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([plantId])
  @@index([reminderAt])
}

/// Simple key/value app settings (e.g. kusumPlantsRoot)
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
