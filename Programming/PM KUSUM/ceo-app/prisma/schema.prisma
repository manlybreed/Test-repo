generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Prisma 6 — URL in schema; docker compose on port 5433

enum Role {
  CEO
}

enum AgreementStatus {
  DRAFT
  FINAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TimeSessionKind {
  POMODORO
  BREAK
  MANUAL
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  role         Role          @default(CEO)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  chatThreads  ChatThread[]
  tasks        Task[]
  timeSessions TimeSession[]
}

model CompanyProfile {
  id                   String   @id @default(cuid())
  legalName            String
  tradeName            String?
  addressLine1         String
  addressLine2         String?
  city                 String
  state                String
  stateCode            String
  pincode              String?
  gstin                String
  pan                  String?
  email                String?
  phone                String?
  bankName             String?
  bankAccount          String?
  bankIfsc             String?
  hsnDefault           String   @default("998313")
  /// UNDER_5CR | OVER_5CR — drives e-invoice readiness messaging
  aatoBand             String   @default("UNDER_5CR")
  eInvoiceEnabled      Boolean  @default(false)
  /// BluRidge consulting = false; goods traders would enable stock register
  maintainsStockLedger Boolean  @default(false)
  retentionMonths      Int      @default(72)
  booksLockedBefore    DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Client {
  id           String      @id @default(cuid())
  name         String
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  stateCode    String?
  pincode      String?
  gstin        String?
  pan          String?
  email        String?
  phone        String?
  /// Point of contact name
  pocName      String?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  agreements   Agreement[]
  invoices     Invoice[]
}

model Agreement {
  id              String              @id @default(cuid())
  clientId        String?
  client          Client?             @relation(fields: [clientId], references: [id])
  clientName      String
  clientAddress   String?
  clientGstin     String?
  clientPan       String?
  spvName         String?
  plantCount      Int                 @default(1)
  tokenFeePerPlant Float              @default(40000)
  successFeePct   Float               @default(1)
  successFeeFlat  Float?              // INR flat success fee when not %-based
  gstPct          Float               @default(18)
  designatedLender String?
  interestRange   String?
  minLoan         String?
  maxLoan         String?
  tenure          String?
  moratorium      String?
  effectiveDate   DateTime            @default(now())
  termMonths      Int                 @default(9)
  tailMonths      Int                 @default(24)
  status          AgreementStatus     @default(DRAFT)
  isImported      Boolean             @default(false)
  notes           String?
  inputsJson      Json?
  filePath        String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  versions        AgreementVersion[]
  invoices        Invoice[]
}

model AgreementVersion {
  id          String    @id @default(cuid())
  agreementId String
  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  version     Int
  filePath    String
  inputsJson  Json?
  createdAt   DateTime  @default(now())
}

model Invoice {
  id                       String        @id @default(cuid())
  number                   String        @unique
  /// PROFORMA | TAX_INVOICE | CREDIT_NOTE | DEBIT_NOTE | RECEIPT_VOUCHER | REFUND_VOUCHER
  documentType             String        @default("TAX_INVOICE")
  /// DRAFT | ISSUED | CANCELLED
  status                   String        @default("ISSUED")
  financialYear            String?
  seriesCode               String?
  sequenceNo               Int?
  clientId                 String?
  client                   Client?       @relation(fields: [clientId], references: [id])
  agreementId              String?
  agreement                Agreement?    @relation(fields: [agreementId], references: [id])
  buyerName                String
  buyerAddress             String?
  buyerGstin               String?
  buyerState               String?
  buyerStateCode           String?
  placeOfSupplyState       String?
  placeOfSupplyStateCode   String?
  reverseCharge            Boolean       @default(false)
  roundOff                 Float         @default(0)
  invoiceDate              DateTime      @default(now())
  dueDate                  DateTime?
  remarks                  String?
  serviceDesc              String?
  taxableTotal             Float
  cgstAmount               Float
  sgstAmount               Float
  igstAmount               Float         @default(0)
  grandTotal               Float
  amountInWords            String?
  paymentStatus            String?       // PAID | UNPAID | PARTIAL | OVERDUE
  tdsDeducted              Boolean       @default(false)
  tdsPercent               Float?        // 5 | 10 | 20
  tdsAmount                Float?        // legacy — unused in UI
  gstEntity                String?       // DEL | RAJ
  isImported               Boolean       @default(false)
  sourceFilePath           String?
  rawExtract               String?
  filePath                 String?
  convertedFromId          String?
  convertedFrom            Invoice?      @relation("InvoiceConversion", fields: [convertedFromId], references: [id])
  convertedTo              Invoice[]     @relation("InvoiceConversion")
  originalInvoiceId        String?
  originalInvoice          Invoice?      @relation("InvoiceAdjustment", fields: [originalInvoiceId], references: [id])
  adjustments              Invoice[]     @relation("InvoiceAdjustment")
  cancelReason             String?
  refundAmount             Float?
  refundDate               DateTime?
  refundMode               String?
  refundReference          String?
  refundReason             String?
  irn                      String?
  irnAckNo                 String?
  irnAckDate               DateTime?
  signedQr                 String?
  /// JSON audit of AI suggestions vs issued payload
  aiSuggestionLog          String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  lines                    InvoiceLine[]
  outwardEntries           OutwardSupplyEntry[]
  advanceEntries           AdvanceLedgerEntry[]

  @@index([documentType, status])
  @@index([financialYear, seriesCode])
  @@index([originalInvoiceId])
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  hsn         String  @default("998313")
  quantity    Float   @default(1)
  rate        Float
  amount      Float
  taxRate     Float   @default(18)
  discount    Float   @default(0)
  uqc         String?
  sortOrder   Int     @default(0)
}

model Employee {
  id              String       @id @default(cuid())
  name            String
  employeeCode    String?      @unique
  designation     String?
  department      String?
  email           String?      // personal email
  emailOfficial   String?      // company / official email (manual)
  phone           String?
  pan             String?
  aadhaar         String?
  uan             String?
  addressLine1    String?
  city            String?
  state           String?
  pincode         String?
  bankAccount     String?
  bankIfsc        String?
  bankName        String?
  bankBranch      String?
  basic           Float
  hra             Float        @default(0)
  special         Float        @default(0)
  otherAllow      Float        @default(0)
  pf              Float        @default(0)
  professionalTax Float        @default(0)
  tdsPercent      Float        @default(0)  // TDS rate % applied on gross
  otherDeduct     Float        @default(0)
  joinDate        DateTime?
  dateOfBirth     DateTime?
  photoPath       String?
  panDocPath      String?
  aadhaarDocPath  String?
  agreementPath   String?
  bankDocPath     String?
  salarySlipPath  String?      // source salary slip used for breakup
  notes           String?
  rawExtract      String?
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  slips           SalarySlip[]
}

model SalarySlip {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month        Int
  year         Int
  basic        Float
  hra          Float
  special      Float
  otherAllow   Float
  gross        Float
  pf           Float
  professionalTax Float
  tds          Float
  otherDeduct  Float
  totalDeduct  Float
  netPay       Float
  amountInWords String?
  filePath     String?
  paymentStatus String  @default("UNPAID") // PAID | UNPAID
  createdAt    DateTime @default(now())

  @@unique([employeeId, month, year])
}

model Task {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  projectTag    String?
  clientTag     String?
  status        TaskStatus    @default(TODO)
  estimateMin   Int?
  /// Optional link back to CEO mail
  mailMessageId String?
  mailThreadId  String?
  dueAt         DateTime?
  /// P1 | P2 | P3 | P4 | NONE
  priority      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      TimeSession[]

  @@index([mailThreadId])
  @@index([dueAt])
}

model TimeSession {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId      String?
  task        Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  kind        TimeSessionKind @default(MANUAL)
  startedAt   DateTime
  endedAt     DateTime?
  durationSec Int?
  notes       String?
  createdAt   DateTime        @default(now())
}

model ChatThread {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String        @default("CEO Assistant")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id        String     @id @default(cuid())
  threadId  String
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role      String
  content   String
  toolCalls Json?
  createdAt DateTime   @default(now())
}

/// Per series + financial year counter. id = "{seriesCode}:{financialYear}" e.g. INV:2025-26
model InvoiceSequence {
  id      String @id
  lastNum Int    @default(0)
}

model Expense {
  id                     String   @id @default(cuid())
  date                   DateTime
  vendor                 String
  vendorGstin            String?
  vendorAddress          String?
  amount                 Decimal  @db.Decimal(12, 2)
  category               String
  subCategory            String?
  description            String?
  paymentMode            String?
  gstAmount              Decimal? @db.Decimal(12, 2)
  cgstAmount             Decimal? @db.Decimal(12, 2)
  sgstAmount             Decimal? @db.Decimal(12, 2)
  igstAmount             Decimal? @db.Decimal(12, 2)
  placeOfSupplyStateCode String?
  hsn                    String?
  itcEligible            Boolean  @default(true)
  gstEntity              String?  // DEL | RAJ
  invoiceNo              String?
  invoiceNoNorm          String?
  billedTo               String?
  billedToPartyId        String?
  billedToParty          BilledToParty? @relation(fields: [billedToPartyId], references: [id], onDelete: SetNull)
  ourGstMentioned        Boolean?
  billedGstin            String?
  contentHash            String?
  filePath               String?
  rawExtract             String?
  notes                  String?
  needsReview            Boolean  @default(false)
  /// ACTIVE | STRUCK — never hard-delete within retention
  status                 String   @default("ACTIVE")
  struckOutAt            DateTime?
  struckOutReason        String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  inwardEntries          InwardSupplyEntry[]

  @@index([invoiceNoNorm])
  @@index([contentHash])
  @@index([billedToPartyId])
  @@index([status])
}

/// Canonical bill-to party (deduped across expense receipts)
model BilledToParty {
  id            String          @id @default(cuid())
  canonicalName String
  normalized    String          @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  aliases       BilledToAlias[]
  expenses      Expense[]
}

model BilledToAlias {
  id        String       @id @default(cuid())
  partyId   String
  party     BilledToParty @relation(fields: [partyId], references: [id], onDelete: Cascade)
  rawName   String
  normalized String
  createdAt DateTime     @default(now())

  @@unique([partyId, normalized])
  @@index([normalized])
}

/// PM KUSUM plant / project finance file — folder-backed KYC pack + disclosure form
model KusumPlant {
  id                 String   @id @default(cuid())
  name               String
  /// Filename prefix e.g. "Solarseed Agri"
  plantShort         String?
  folderPath         String   @unique
  status             String   @default("DRAFT") // DRAFT | EXTRACTED | FORM_READY
  documentsFound     Int      @default(0)
  extractSummary     String?
  rawExtract         String?  // JSON from AI
  disclosureFilePath String?
  notes              String?
  /// Portfolio fields shown on the plants table
  capacityMw         String?
  tehsil             String?
  district           String?
  dprName            String?
  epcName            String?
  tariff             String?
  bankName           String?
  /// Success fee % of sanction (finance owner only) — use when not flat
  feePercent         Float?
  /// Flat success fee INR (finance owner only) — takes priority over feePercent
  feeFlat            Float?
  /// Sanctioned loan amount INR (finance owner only)
  sanctionAmount     Float?
  /// Quoted / expected interest rate %
  interestRate       Float?
  /// DOCUMENTATION | MAIL | FIELD_VISIT | CMA | SANCTION | DISBURSEMENT
  financeStage       String   @default("DOCUMENTATION")
  docsCompleteAt     DateTime?
  mailSentAt         DateTime?
  fieldVisitAt       DateTime?
  cmaAt              DateTime?
  sanctionAt         DateTime?
  disbursementAt     DateTime?
  sanctionLetterPath String?
  /// ACTIVE | INACTIVE
  activeStatus       String   @default("ACTIVE")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  parties      PlantParty[]
  requirements PlantDocRequirement[]
  fileComments PlantFileComment[]
  tasks        PlantTask[]
}

/// Director / promoter under a plant (maps to Directors KYC/<folderName>/)
model PlantParty {
  id         String   @id @default(cuid())
  plantId    String
  plant      KusumPlant @relation(fields: [plantId], references: [id], onDelete: Cascade)
  name       String
  role       String   @default("DIRECTOR") // DIRECTOR | PROMOTER
  folderName String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  requirements PlantDocRequirement[]

  @@index([plantId])
  @@unique([plantId, folderName])
}

/// Global checklist template (SPV / Directors / Plant / Land / …)
model DocTypeCatalog {
  id          String   @id @default(cuid())
  code        String   @unique
  docGroup    String   // SPV | DIRECTORS | PLANT | LAND | EPC | DPR | MISC | THIRD_PARTY
  label       String
  description String?
  scope       String   @default("PLANT") // PLANT | PARTY
  required    Boolean  @default(true)
  folderHint  String
  /// JSON string array of filename keywords
  matchHints  String   @default("[]")
  namePattern String   @default("{plantShort}-{label}")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requirements PlantDocRequirement[]
}

/// Per-plant (and optional per-party) checklist row
model PlantDocRequirement {
  id               String    @id @default(cuid())
  plantId          String
  plant            KusumPlant @relation(fields: [plantId], references: [id], onDelete: Cascade)
  catalogId        String
  catalog          DocTypeCatalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  partyId          String?
  party            PlantParty? @relation(fields: [partyId], references: [id], onDelete: Cascade)
  received         Boolean   @default(false)
  receivedAt       DateTime?
  fileRelativePath String?
  source           String?   // IMPORT | UPLOAD | MANUAL
  notes            String?
  /// REQUIRED | OPTIONAL | NA — NA means not needed for this plant
  applicability    String    @default("REQUIRED")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([plantId, catalogId, partyId])
  @@index([plantId])
  @@index([catalogId])
}

/// Per-file comment on a plant folder file (keyed by relative path)
model PlantFileComment {
  id           String     @id @default(cuid())
  plantId      String
  plant        KusumPlant @relation(fields: [plantId], references: [id], onDelete: Cascade)
  relativePath String
  comment      String     @default("")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([plantId, relativePath])
  @@index([plantId])
}

/// Tasks tied to a PM KUSUM plant / project
model PlantTask {
  id           String     @id @default(cuid())
  plantId      String
  plant        KusumPlant @relation(fields: [plantId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  status       TaskStatus @default(TODO)
  /// LOW | MEDIUM | HIGH | CRITICAL
  urgency      String     @default("MEDIUM")
  reminderAt   DateTime?
  /// GENTLE | NORMAL | URGENT
  reminderTone String     @default("NORMAL")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([plantId])
  @@index([reminderAt])
}

/// Simple key/value app settings (e.g. kusumPlantsRoot)
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Outward supply register (sales) — Rule 56
model OutwardSupplyEntry {
  id                     String    @id @default(cuid())
  financialYear          String
  gstEntity              String?
  documentType           String
  documentNumber         String
  documentDate           DateTime
  invoiceId              String?
  invoice                Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  buyerName              String
  buyerGstin             String?
  buyerAddress           String?
  placeOfSupplyStateCode String?
  reverseCharge          Boolean   @default(false)
  taxableValue           Float
  cgstAmount             Float     @default(0)
  sgstAmount             Float     @default(0)
  igstAmount             Float     @default(0)
  grandTotal             Float
  /// DOC | PORTAL | MANUAL
  source                 String    @default("DOC")
  struckOutAt            DateTime?
  struckOutReason        String?
  retentionUntil         DateTime
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([financialYear, gstEntity])
  @@index([documentDate])
  @@index([invoiceId])
  @@index([struckOutAt])
}

/// Inward supply register (purchases)
model InwardSupplyEntry {
  id                     String    @id @default(cuid())
  financialYear          String
  gstEntity              String?
  supplierName           String
  supplierGstin          String?
  supplierAddress        String?
  billNumber             String?
  billDate               DateTime
  hsn                    String?
  placeOfSupplyStateCode String?
  reverseCharge          Boolean   @default(false)
  taxableValue           Float
  cgstAmount             Float     @default(0)
  sgstAmount             Float     @default(0)
  igstAmount             Float     @default(0)
  grandTotal             Float
  expenseId              String?
  expense                Expense?  @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  /// DOC | PORTAL | MANUAL
  source                 String    @default("DOC")
  itcEligible            Boolean   @default(true)
  struckOutAt            DateTime?
  struckOutReason        String?
  retentionUntil         DateTime
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  itcEntries             ItcLedgerEntry[]

  @@index([financialYear, gstEntity])
  @@index([billDate])
  @@index([expenseId])
  @@index([supplierGstin])
  @@index([struckOutAt])
}

/// ITC ledger — eligible / claimed / reversed
model ItcLedgerEntry {
  id               String            @id @default(cuid())
  financialYear    String
  gstEntity        String?
  periodYm         String
  inwardEntryId    String?
  inwardEntry      InwardSupplyEntry? @relation(fields: [inwardEntryId], references: [id], onDelete: SetNull)
  /// ELIGIBLE | CLAIMED | REVERSED | INELIGIBLE
  status           String            @default("ELIGIBLE")
  cgstAmount       Float             @default(0)
  sgstAmount       Float             @default(0)
  igstAmount       Float             @default(0)
  totalItc         Float             @default(0)
  notes            String?
  source           String            @default("DOC")
  struckOutAt      DateTime?
  struckOutReason  String?
  retentionUntil   DateTime
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([financialYear, gstEntity])
  @@index([periodYm])
  @@index([inwardEntryId])
  @@index([struckOutAt])
}

/// Advance ledger — received / paid / adjusted
model AdvanceLedgerEntry {
  id               String    @id @default(cuid())
  financialYear    String
  gstEntity        String?
  /// RECEIVED | PAID | ADJUSTED | REFUNDED
  kind             String
  partyName        String
  partyGstin       String?
  amount           Float
  taxAmount        Float     @default(0)
  documentNumber   String?
  documentDate     DateTime
  invoiceId        String?
  invoice          Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  notes            String?
  source           String    @default("DOC")
  struckOutAt      DateTime?
  struckOutReason  String?
  retentionUntil   DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([financialYear, gstEntity])
  @@index([documentDate])
  @@index([invoiceId])
  @@index([struckOutAt])
}

/// Stock ledger scaffold (unused when CompanyProfile.maintainsStockLedger=false)
model StockLedgerEntry {
  id              String    @id @default(cuid())
  financialYear   String
  itemCode        String?
  itemDescription String
  uqc             String?
  /// OPENING | RECEIPT | SUPPLY | LOSS | CLOSING
  movement        String
  quantity        Float
  documentRef     String?
  movementDate    DateTime
  notes           String?
  struckOutAt     DateTime?
  struckOutReason String?
  retentionUntil  DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([financialYear])
  @@index([movementDate])
}

/// Immutable audit trail — Rule 56(8) + mail agentic actions
model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  /// CREATE | UPDATE | STRIKE | EXPORT | SEED | MAIL_*
  action     String
  beforeJson String?
  afterJson  String?
  reason     String?
  actorUserId String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─── AI Email Client (akshay@ / CEO_MAIL_*) ─────────────────────────

model MailAccount {
  id            String   @id @default(cuid())
  /// e.g. akshay@thebluridge.com
  address       String   @unique
  displayName   String?
  /// ceo_env → getCeoMailConfig()
  credentialKey String   @default("ceo_env")
  userId        String?
  styleJson     String?
  lastSyncedAt  DateTime?
  lastVisitAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  folders       MailFolder[]
  threads       MailThread[]
  messages      MailMessage[]
  signatures    MailSignature[]
  outbox        MailOutbox[]
  reminders     MailReminder[]
  labelRules    MailLabelRule[]
  syncStates    MailSyncState[]
  autonomy      MailAutonomySettings?
}

model MailFolder {
  id          String @id @default(cuid())
  accountId   String
  account     MailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  path        String
  name        String
  /// INBOX | SENT | DRAFTS | TRASH | OTHER
  role        String @default("OTHER")
  uidValidity BigInt?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  messages    MailMessage[]
  syncState   MailSyncState?

  @@unique([accountId, path])
  @@index([accountId, role])
}

model MailThread {
  id             String   @id @default(cuid())
  accountId      String
  account        MailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subject        String
  snippet        String?
  participantsJson String @default("[]")
  lastMessageAt  DateTime
  unreadCount    Int      @default(0)
  /// P1 | P2 | P3 | P4 | NONE
  priority       String   @default("NONE")
  labelsJson     String   @default("[]")
  snoozedUntil   DateTime?
  clientId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  messages       MailMessage[]
  reminders      MailReminder[]

  @@index([accountId, lastMessageAt])
  @@index([accountId, priority])
  @@index([snoozedUntil])
}

model MailMessage {
  id            String   @id @default(cuid())
  accountId     String
  account       MailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  folderId      String
  folder        MailFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  threadId      String
  thread        MailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  rfcMessageId  String?
  imapUid       Int
  inReplyTo     String?
  referencesHdr String?
  fromAddress   String
  fromName      String?
  toAddresses   String   @default("[]")
  ccAddresses   String   @default("[]")
  subject       String
  date          DateTime
  seen          Boolean  @default(false)
  flagged       Boolean  @default(false)
  answered      Boolean  @default(false)
  bodyText      String?
  bodyHtml      String?
  snippet       String?
  hasAttachments Boolean @default(false)
  listUnsubscribe String?
  clientId      String?
  rawPath       String?
  /// Denormalized for FTS helper queries
  searchText    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  attachments   MailAttachment[]
  aiCache       MailAiCache[]

  @@unique([folderId, imapUid])
  @@index([accountId, date])
  @@index([threadId])
  @@index([rfcMessageId])
  @@index([fromAddress])
}

model MailAttachment {
  id            String @id @default(cuid())
  messageId     String
  message       MailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  filename      String
  contentType   String?
  size          Int    @default(0)
  storagePath   String?
  extractedText String?
  /// PENDING | DONE | FAILED | SKIPPED
  extractStatus String @default("PENDING")
  createdAt     DateTime @default(now())

  @@index([messageId])
}

model MailOutbox {
  id             String   @id @default(cuid())
  accountId      String
  account        MailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  toAddresses    String
  ccAddresses    String   @default("[]")
  bccAddresses   String   @default("[]")
  subject        String
  bodyHtml       String
  bodyText       String?
  inReplyTo      String?
  referencesHdr  String?
  /// DRAFT | QUEUED | SCHEDULED | SENT | FAILED | CANCELLED
  status         String   @default("DRAFT")
  sendAt         DateTime?
  undoUntil      DateTime?
  idempotencyKey String   @unique
  smtpMessageId  String?
  invoiceId      String?
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([accountId, status])
  @@index([sendAt])
}

model MailSignature {
  id         String  @id @default(cuid())
  accountId  String
  account    MailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name       String
  htmlBody   String
  isDefault  Boolean @default(false)
  sortOrder  Int     @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([accountId])
}

model MailSyncState {
  id        String @id @default(cuid())
  accountId String
  account   MailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  folderId  String @unique
  folder    MailFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  lastUid   Int    @default(0)
  uidNext   Int?
  modseq    String?
  updatedAt DateTime @updatedAt

  @@index([accountId])
}

model MailAiCache {
  id         String @id @default(cuid())
  messageId  String?
  message    MailMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  threadId   String?
  /// SUMMARY | TRIAGE | DRAFT | DIGEST | COMMITMENT | ATTACHMENT
  kind       String
  payloadJson String
  model      String?
  createdAt  DateTime @default(now())

  @@index([threadId, kind])
  @@index([messageId, kind])
}

model MailReminder {
  id         String @id @default(cuid())
  accountId  String
  account    MailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  threadId   String?
  thread     MailThread? @relation(fields: [threadId], references: [id], onDelete: SetNull)
  taskId     String?
  /// FOLLOW_UP | SNOOZE | COMMITMENT
  kind       String
  dueAt      DateTime
  /// GENTLE | NORMAL | URGENT
  tone       String @default("NORMAL")
  note       String?
  dismissed  Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([accountId, dueAt])
  @@index([dismissed])
}

model MailLabelRule {
  id          String  @id @default(cuid())
  accountId   String
  account     MailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name        String
  /// JSON match: { fromContains?, subjectContains?, label }
  matchJson   String
  label       String
  enabled     Boolean @default(true)
  sortOrder   Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([accountId, enabled])
}

model MailAutonomySettings {
  id                 String  @id @default(cuid())
  accountId          String  @unique
  account            MailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  autoLabel          Boolean @default(true)
  autoPriority       Boolean @default(true)
  autoMarkRead       Boolean @default(false)
  requireConfirmSend Boolean @default(true)
  updatedAt          DateTime @updatedAt
}
